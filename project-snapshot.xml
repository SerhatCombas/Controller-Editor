        s = TranslationalSpring("k1", k=100.0)
        eqs = s.symbolic_equations()
        across_eq = [e for e in eqs if e.provenance == "across_diff"][0]
        v_a = s._setup.symbols["v_a"]
        v_b = s._setup.symbols["v_b"]
        # rhs should be v_b - v_a
