        self.assertFalse(result.is_strictly_proper)

    def test_SM_10c_acceleration_dc_gain_is_zero(self) -> None:
        """H_accel(0) = 0: static force causes zero steady-state acceleration."""
        result = self._build(self.accel_probe)
